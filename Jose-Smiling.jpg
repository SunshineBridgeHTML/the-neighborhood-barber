    font-size: 16px;
    font-weight: 600;
  }

  .paragraph-3 {
    margin: 20px 0;
    font-size: 13px;
    line-height: 16px;
  }

  .footer-logo {
    margin-top: 20px;
    margin-left: 0;
  }

  .body-text {
    text-align: center;
    padding-left: 20px;
    padding-right: 20px;
