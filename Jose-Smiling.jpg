  }

  .bottom-cta {
    text-align: center;
  }

  .div-block-5 {
    grid-column-gap: 10px;
    grid-row-gap: 10px;
    grid-template: "."
                   "."
                   "Area"
                   / 1fr;
  }

  .heading {
    text-align: center;
    margin: 10px auto;
    font-size: 16px;
  }

  .heading.location {
    font-size: 16px;
  }

  .hero-grid {
    max-width: 350px;
    margin-left: auto;
    margin-right: auto;
    padding: 32px 16px;
  }

  .hero-content {
    margin-left: auto;
    margin-right: auto;
    padding: 15px 0 20px;
    overflow: hidden;
  }

  .hero-heading {
    font-family: Arial, Helvetica Neue, Helvetica, sans-serif;
    font-size: 32px;
  }

  .hero-text {
    text-align: left;
    max-width: 320px;
    font-size: 11px;
  }

  .hero-cta {
    grid-column-gap: 10px;
    grid-row-gap: 10px;
  }

  .button {
    text-align: center;
    margin-top: 10px;
    margin-left: 0;
    font-size: 11px;
  }

  .button.nav {
    margin-top: 10px;
    padding-left: 40px;
    padding-right: 40px;
  }

  .button.service {
    padding-left: 8px;
    padding-right: 8px;
    font-size: 10px;
  }

  .button.hero {
    padding: 5px 10px;
  }

  .button.review {
    margin-top: 20px;
    margin-left: auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .button.cta-bottom {
    margin-top: 20px;
    margin-left: auto;
  }

  .navbar-2 {
    border: 0 solid #000;
  }

  .navbar-3 {
    border-left-width: 0;
  }

  .section-3 {
    max-width: 350px;
  }

  .grid-2 {
    border-right: 1px solid var(--service-border);
  }

  .stat-block {
    padding: 10px;
    font-size: 12px;
  }

  .stat-text {
    font-size: 14px;
  }

  .gold-stat {
    font-size: 22px;
  }

  .stat-subtext {
    font-size: 14px;
  }

  .services-header {
    margin-left: 10px;
    margin-right: 10px;
  }

  .service-grid {
    grid-template: "Area"
                   "Area-2"
                   / 1.5fr;
    margin-left: 10px;
    margin-right: 10px;
  }

  .service-wrapper {
    min-height: 250px;
    padding: 10px 15px;
  }

  .menu-item-headshave {
    border-bottom-color: var(--service-border);
  }

  .service-bullet-default {
    width: 4px;
  }

  .menu-item-slkinfade {
    border-bottom-color: var(--service-border);
  }

  .service-menu-item-default {
    border-style: none none solid;
    border-bottom-color: var(--service-border);
  }

  .menu-item-beardtrim, .memu-item-towelshave, .menu-item-buzzcut {
    border-bottom-color: var(--service-border);
  }

  .service-bullet-skinfade, .service-bullet-headshave, .service-bullet-beardtrim, .service-bullet-towelshave, .service-bullet-buzzcut {
    width: 4px;
  }

  .menu-text-skinfade, .menu-text-headshave, .menu-text-beardtrim {
    color: var(--service-bullet);
  }

  .service-panel-skinfade, .service-panel-headshave, .service-panel-beardtrim, .service-panel-towelshave, .service-panel-buzzcut {
    display: none;
  }

  .hero-content-left {
    display: none;
    overflow: hidden;
  }

  .button-price-grid {
    grid-column-gap: 8px;
    grid-row-gap: 8px;
  }

  .section-4 {
    width: 100%;
  }

  .review-layout {
    max-width: 350px;
    margin-left: 0;
    margin-right: 0;
    padding-left: 0;
    padding-right: 0;
  }

  .reviews-left {
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    padding-top: 25px;
    padding-bottom: 25px;
    padding-right: 20px;
  }

  .review-header {
    font-size: 38px;
  }

  .review-statement {
    padding-bottom: 20px;
  }

  .div-block-14 {
    margin-top: 3px;
  }

  .div-block-17 {
    padding-left: 20px;
    padding-right: 20px;
  }

  .review-item {
    padding-top: 20px;
    padding-bottom: 20px;
  }

  .price-text {
    color: var(--service-bullet);
  }
}

